# Copy to .env and fill in. .env is gitignored — never commit real keys.

# NYT Archive API key — https://developer.nytimes.com (enable the Archive API)
NYT_API_KEY=

# Groq API key for the "this month in history" blurb — https://console.groq.com
GROQ_API_KEY=

# Optional: override the Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
